# ── Required ──────────────────────────────────────────────────────────────────

# Get this from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID (not username)
# Get it by messaging @userinfobot on Telegram
YOUR_TELEGRAM_ID=123456789

# Get this from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Time for daily briefing (24hr format, your local time)
BRIEFING_TIME=08:00
