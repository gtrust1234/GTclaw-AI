<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.personalassistant.bot</string>

    <key>ProgramArguments</key>
    <array>
        <!-- EDIT THIS: replace YOUR_USERNAME with your Mac username -->
        <string>/Users/YOUR_USERNAME/assistant/venv/bin/python</string>
        <string>/Users/YOUR_USERNAME/assistant/bot.py</string>
    </array>

    <!-- Run at login and keep alive if it crashes -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Wait 10 seconds before restarting if it crashes -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Log output -->
    <key>StandardOutPath</key>
    <!-- EDIT THIS: replace YOUR_USERNAME -->
    <string>/Users/YOUR_USERNAME/assistant_logs/stdout.log</string>
    <key>StandardErrorPath</key>
    <!-- EDIT THIS: replace YOUR_USERNAME -->
    <string>/Users/YOUR_USERNAME/assistant_logs/stderr.log</string>

    <!-- Set working directory -->
    <key>WorkingDirectory</key>
    <!-- EDIT THIS: replace YOUR_USERNAME -->
    <string>/Users/YOUR_USERNAME/assistant</string>

    <!-- Environment — needed so Python finds your .env -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
